# SCDO Project Environment Variables Template
# Copy this file to .env and fill in the actual values.
# DO NOT commit the .env file to version control.

# Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=your-project-id

# NewsAPI Key (https://newsapi.org/)
NEWS_API_KEY=your_news_api_key_here

# OpenWeatherMap API Key (https://openweathermap.org/api)
OWM_API_KEY=your_owm_api_key_here

# AirLabs API Key (https://airlabs.co/)
AIRLABS_API_KEY=your_airlabs_api_key_here

# Google Maps API Key (Distance Matrix enabled)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Port configurations (optional)
PORT=8081
COMBINED_API_PORT=5000
WEATHER_API_PORT=8080

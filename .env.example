# SCDO Environment Variables — Copy to .env and fill in values
GOOGLE_CLOUD_PROJECT=your-firebase-project-id
GOOGLE_MAPS_API_KEY=your-google-maps-key
AIRLABS_API_KEY=your-airlabs-key
OWM_API_KEY=your-openweathermap-key
NEWS_API_KEY=your-newsapi-key
GEMINI_API_KEY=your-gemini-key
GATEWAY_API_KEY=your-secret-api-key-for-gateway
FIRESTORE_COLLECTION=sim_jobs
FIRESTORE_CACHE_COLLECTION=api_cache
PORT=7860
MAX_WORKERS=4
DEFAULT_MC_ITERATIONS=50
MAX_MC_ITERATIONS=500
